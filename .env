# ==========================================================
# IBM watsonx.ai credentials — copy this file to ".env" and
# fill in your own values. NEVER commit the real ".env" file.
# ==========================================================

# IBM Cloud API Key (IAM)  -> https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=P1b4IDAZcq9xUrH-YfnyLB9QSBFTFRRPK_W8IlqhY-0K

# watsonx.ai Project ID -> found in your watsonx.ai project's "Manage" tab
WATSONX_PROJECT_ID=4514a1ea-f493-494f-8ab3-f9be973e4df6

# Regional watsonx.ai base URL (choose the one matching your region)
# us-south : https://us-south.ml.cloud.ibm.com
# eu-de    : https://eu-de.ml.cloud.ibm.com
# eu-gb    : https://eu-gb.ml.cloud.ibm.com
# jp-tok   : https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://au-syd.ml.cloud.ibm.com

# Granite (or any other) foundation model deployed on watsonx.ai
WATSONX_MODEL_ID=ibm/granite-3-3-8b-instruct

# watsonx.ai REST API version (date-based, keep updated periodically)
WATSONX_API_VERSION=2024-05-01

# App environment: development | production
APP_ENV=development

